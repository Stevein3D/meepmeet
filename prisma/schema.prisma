// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"  // Changed from sqlite
  url      = env("DATABASE_URL")
}

// Add this enum for user roles (if not already there)
enum UserRole {
  VISITOR
  MEMBER
  GAME_MASTER
}

model User {
  id        String   @id @default(cuid())
  name      String
  alias     String?
  tagline   String?
  email     String   @unique
  avatar    String?
  bggId     String?
  role      UserRole @default(VISITOR)  // Add this if not already there
  createdAt DateTime @default(now())
  
  ownedGames    UserGame[]
  gameWants     UserGameWant[]
  gameRatings   GameRating[]
  hostedEvents  Event[]        @relation("EventHost")
  eventRsvps    EventAttendee[]
  playSessions  SessionPlayer[]
  sessionWins   PlaySession[]  @relation("SessionWinner")
  tablePlayers  TablePlayer[]
  dateVotes     EventDateVote[]
  eventGuests   EventGuest[]   @relation("GuestBringer")
  gameRequests  GameRequest[]
}

model Game {
  id            String   @id @default(cuid())
  bggId         Int?     @unique
  name          String
  image         String?
  description   String?
  mechanisms    String[]
  categories    String[]
  minPlayers    Int
  maxPlayers    Int
  playtime      Int
  complexity    Float?
  yearPublished Int?
  createdAt     DateTime @default(now())

  owners       UserGame[]
  wants        UserGameWant[]
  ratings      GameRating[]
  playSessions PlaySession[]
  eventTables  EventTable[]
  gameRequests GameRequest[]
}

model UserGameWant {
  userId String
  gameId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
}

model UserGame {
  userId String
  gameId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@id([userId, gameId])
}

model Event {
  id            String   @id @default(cuid())
  title         String
  date          DateTime
  location      String?
  notes         String?
  hostId        String
  dateConfirmed Boolean  @default(false)
  host          User     @relation("EventHost", fields: [hostId], references: [id])
  createdAt     DateTime @default(now())

  attendees    EventAttendee[]
  playSessions PlaySession[]
  rounds       EventRound[]
  datePolls    EventDatePoll[]
  guests       EventGuest[]
  gameRequests GameRequest[]
}

model EventAttendee {
  eventId String
  userId  String
  rsvpStatus String  // "yes", "no", "maybe"
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([eventId, userId])
}

model PlaySession {
  id        String   @id @default(cuid())
  gameId    String
  eventId   String?
  date      DateTime
  duration  Int?     // minutes
  notes     String?
  winnerId  String?
  createdAt DateTime @default(now())
  
  game    Game            @relation(fields: [gameId], references: [id])
  event   Event?          @relation(fields: [eventId], references: [id])
  winner  User?           @relation("SessionWinner", fields: [winnerId], references: [id])
  players SessionPlayer[]
}

model SessionPlayer {
  sessionId String
  userId    String
  session   PlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

model EventRound {
  id        String      @id @default(cuid())
  eventId   String
  number    Int
  label     String?
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tables EventTable[]

  @@unique([eventId, number])
}

model EventTable {
  id        String      @id @default(cuid())
  roundId   String
  gameId    String?
  label     String?
  seats     Int
  order       Int         @default(0)
  unranked    Boolean     @default(false)
  cooperative Boolean     @default(false)
  teams       Int?
  createdAt   DateTime    @default(now())

  round   EventRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  game    Game?         @relation(fields: [gameId], references: [id], onDelete: SetNull)
  players TablePlayer[]
}

model TablePlayer {
  id         String     @id @default(cuid())
  tableId    String
  userId     String?
  playerName String?
  isGM       Boolean    @default(false)
  placement  Int?
  score      Int?
  order      Int        @default(0)

  table EventTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model GameRating {
  userId    String
  gameId    String
  rating    Float
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
}

model EventDatePoll {
  id          String    @id @default(cuid())
  eventId     String
  date        DateTime
  confirmedAt DateTime?

  event Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes EventDateVote[]

  @@unique([eventId, date])
}

model EventDateVote {
  optionId String
  userId   String

  option EventDatePoll @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([optionId, userId])
}

model EventGuest {
  id        String @id @default(cuid())
  eventId   String
  bringerId String
  name      String

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bringer User  @relation("GuestBringer", fields: [bringerId], references: [id], onDelete: Cascade)
}

model GameRequest {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  eventId   String?
  note      String?
  createdAt DateTime @default(now())

  game  Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId, eventId])
}